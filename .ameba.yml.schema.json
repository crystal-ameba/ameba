    "Lint/EmptyLoop": {
      "$ref": "#/definitions/BaseRule",
      "title": "Lint/EmptyLoop",
      "description": "Disallows empty loops\nhttps://crystal-ameba.github.io/ameba/Ameba/Rule/Lint/EmptyLoop.html",
